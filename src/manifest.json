{
  "manifest_version": 3,
  "name": "Excalicon",
  "description": "Search Google Material Symbols and drag them into Excalidraw.",
  "version": "0.2.0",
  "minimum_chrome_version": "116",
  "permissions": ["sidePanel"],
  "host_permissions": ["https://excalidraw.com/*", "https://*.excalidraw.com/*"],
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "Open Excalicon",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://excalidraw.com/*", "https://*.excalidraw.com/*"],
      "js": ["excalidraw-drop-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/rounded/*.svg"],
      "matches": ["https://excalidraw.com/*", "https://*.excalidraw.com/*"]
    }
  ]
}
